// Prisma Schema para Ágape Gestor
// Sistema de gestão financeira para instituições religiosas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN      // Administrador total do sistema
  TREASURER  // Tesoureiro - pode criar e editar transações
  COUNCIL    // Conselho - apenas leitura e relatórios
  PASTOR     // Pastor - apenas leitura e relatórios
  VIEWER     // Visualizador - apenas leitura básica
}

enum TransactionType {
  INCOME   // Entrada (Dízimos, Ofertas)
  EXPENSE  // Saída (Despesas operacionais)
}

enum IncomeCategory {
  TITHE      // Dízimo
  OFFERING   // Oferta
  DONATION   // Doação
  EVENT      // Evento especial
  OTHER      // Outros
}

enum ExpenseCategory {
  MAINTENANCE  // Manutenção predial
  UTILITIES    // Utilidades (água, luz, internet)
  SALARY       // Salários
  PREBEND      // Prebenda pastoral
  MISSION      // Missões
  EVENT        // Eventos
  SUPPLY       // Suprimentos
  OTHER        // Outros
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ==================== MODELS ====================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Hash bcrypt
  role      UserRole @default(VIEWER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions     Transaction[]
  auditLogs        AuditLog[]
  createdCategories Category[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        TransactionType
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  // Relations
  createdBy    User          @relation(fields: [createdById], references: [id])
  transactions Transaction[]

  @@unique([name, type])
  @@index([type, active])
  @@map("categories")
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  categoryId  String
  amount      Decimal         @db.Decimal(12, 2) // Precisão financeira
  description String
  date        DateTime        @default(now())

  // Metadata para dízimos nominais (opcional)
  donorName   String?

  // Comprovante (futuro: URL do arquivo no storage)
  receiptUrl  String?

  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  category  Category   @relation(fields: [categoryId], references: [id])
  createdBy User       @relation(fields: [createdById], references: [id])
  auditLogs AuditLog[]

  @@index([type, date])
  @@index([createdById])
  @@index([categoryId])
  @@map("transactions")
}

// Trilha de auditoria imutável
model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  entity    String      // Nome da entidade (Transaction, User, etc)
  entityId  String      // ID da entidade afetada
  oldValue  Json?       // Estado anterior (para UPDATE/DELETE)
  newValue  Json?       // Estado novo (para CREATE/UPDATE)
  userId    String
  ipAddress String?
  userAgent String?
  timestamp DateTime    @default(now())

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  transaction  Transaction? @relation(fields: [transactionId], references: [id])
  transactionId String?

  @@index([entity, entityId])
  @@index([userId])
  @@index([timestamp])
  @@map("audit_logs")
}

// View materializada para relatórios (PostgreSQL)
// Calculada periodicamente via cron job
model MonthlyReport {
  id            String   @id @default(uuid())
  year          Int
  month         Int
  totalIncome   Decimal  @db.Decimal(12, 2)
  totalExpense  Decimal  @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  transactionCount Int
  generatedAt   DateTime @default(now())

  @@unique([year, month])
  @@index([year, month])
  @@map("monthly_reports")
}
